# Copy to backend/.env and fill in. Never commit the real .env (it is gitignored).

# Required — Anthropic API key for the bull/bear/verifier agents.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — Alpha Vantage key, only used for the earnings-call spin check.
ALPHAVANTAGE_API_KEY=your-alphavantage-key-here

# --- deployment tuning (optional; sensible defaults if unset) ---
# Comma-separated allowed origins for the browser. Set to your site in prod,
# e.g. https://verity.vercel.app  (default "*" allows any origin — dev only).
VERITY_CORS_ORIGINS=*

# Per-IP request burst limit, per 60 seconds.
VERITY_RATE_PER_MIN=10

# Global cap on NEW (uncached) analyses per day — protects your API spend.
VERITY_DAILY_NEW_ANALYSES=150
